# ─── Servidor ────────────────────────────────────────────────────────────────
PORT=4000

# ─── Autenticação (obrigatório) ───────────────────────────────────────────────
# Segredo para assinar tokens JWT. Use um valor longo e aleatório em produção.
JWT_SECRET=troque-por-um-segredo-longo-e-aleatorio

# Admin do sistema (não precisa de cadastro no banco).
# AMBAS as variáveis são obrigatórias para o login do admin funcionar.
ADMIN_EMAIL=admin@exemplo.com
ADMIN_PASSWORD=senha-segura-aqui

# ─── Banco de dados ───────────────────────────────────────────────────────────
# Deixe comentado para usar SQLite local (desenvolvimento).
# Descomente e preencha para usar Supabase (produção).
# SUPABASE_DB_URL=postgresql://usuario:senha@host:5432/banco
# SUPABASE_DB_SSL=true

# Diretório para o banco SQLite local (padrão: ./data)
# DATA_DIR=./data

# ─── Google Drive (opcional) ──────────────────────────────────────────────────
# Necessário apenas se quiser armazenar comprovantes no Google Drive.
# Consulte GOOGLE_DRIVE.md para instruções de configuração.
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REFRESH_TOKEN=
# GOOGLE_DRIVE_FOLDER_ID=
# GOOGLE_REDIRECT_URI=https://developers.google.com/oauthplayground
